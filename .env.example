# Required
OPENAI_API_KEY=sk-proj-your-api-key-here

# Caddy HTTPS basic auth (REQUIRED for VPS deployment)
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
CADDY_AUTH_USER=admin
CADDY_AUTH_HASH=$2a$14$CHANGE_ME_GENERATE_WITH_CADDY_HASH_PASSWORD

# Optional overrides (these override values in jarvis.config.json)
# BOT_NAME=Jarvis
# MEET_URL=https://meet.google.com/abc-defg-hij
# LANGUAGE=auto
# TTS_VOICE=nova
# RESPONSE_MODE=name_only
# RUST_LOG=jarvis=info
