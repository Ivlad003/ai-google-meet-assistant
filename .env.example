# Required
OPENAI_API_KEY=sk-proj-your-api-key-here

# Caddy basic auth (protects Web UI)
# Set to false to disable auth (local dev). Default: true
CADDY_AUTH_ENABLED=true
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# IMPORTANT: Escape every $ as $$ in the hash (docker-compose requirement)
# Example: $2a$14$abc... becomes $$2a$$14$$abc...
CADDY_AUTH_USER=admin
CADDY_AUTH_HASH=$$2a$$14$$CHANGE_ME_USE_CADDY_HASH_PASSWORD_COMMAND
# Caddy listen address (use your-domain.com for VPS with auto HTTPS)
# CADDY_LISTEN=:8080

# Optional overrides (these override values in jarvis.config.json)
# BOT_NAME=Jarvis
# MEET_URL=https://meet.google.com/abc-defg-hij
# LANGUAGE=auto
# TTS_VOICE=nova
# RESPONSE_MODE=name_only
# RUST_LOG=jarvis=info
