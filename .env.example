# Required
OPENAI_API_KEY=sk-proj-your-api-key-here

# Basic auth (protects Web UI) — built into Jarvis
# Set AUTH_ENABLED=true and provide a bcrypt hash to enable
AUTH_ENABLED=false
AUTH_USER=admin
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# IMPORTANT: Escape every $ as $$ in the hash (docker-compose requirement)
# Example: $2a$14$abc... becomes $$2a$$14$$abc...
AUTH_HASH=$$2a$$14$$CHANGE_ME_USE_HASH_PASSWORD_COMMAND

# Jarvis config overrides (env vars override jarvis.config.json)
# If no config file exists, set OPENAI_API_KEY to run in env-only mode
# BOT_NAME=Jarvis
# MEET_URL=https://meet.google.com/abc-defg-hij
# LANGUAGE=auto                 (auto, en, uk)
# TTS_VOICE=nova
# OPENAI_MODEL=gpt-5.4
# INTENT_MODEL=gpt-5
# RESPONSE_MODE=smart           (smart, name_only)
# TRANSCRIPTION_MODE=cloud      (cloud, local)
# MAX_RESPONSE_TOKENS=150
# RUST_LOG=jarvis=info
