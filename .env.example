# Required
OPENAI_API_KEY=sk-...

# Optional — can also set via Web UI
# MEET_URL=https://meet.google.com/abc-defg-hij

# Bot settings
# BOT_DISPLAY_NAME=Jarvis
# TRIGGER_PHRASE=hey bot
# LANGUAGE=auto              # auto, en, uk
# TRANSCRIPTION_MODE=cloud   # cloud (OpenAI API) or local (whisper-rs)
# WHISPER_MODEL=small         # local mode: small, medium, large
# OPENAI_MODEL=gpt-4o
# TTS_VOICE=nova
# WEB_UI_PORT=8080
# HEADLESS=false
