# Required
OPENAI_API_KEY=sk-proj-your-api-key-here

# Caddy basic auth (protects Web UI)
# Set to false to disable auth (local dev). Default: true
CADDY_AUTH_ENABLED=true
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# IMPORTANT: Escape every $ as $$ in the hash (docker-compose requirement)
# Example: $2a$14$abc... becomes $$2a$$14$$abc...
CADDY_AUTH_USER=admin
CADDY_AUTH_HASH=$$2a$$14$$CHANGE_ME_USE_CADDY_HASH_PASSWORD_COMMAND
# Caddy listen address (use your-domain.com for VPS with auto HTTPS)
# CADDY_LISTEN=:8080

# Jarvis config overrides (JARVIS_* env vars override jarvis.config.json)
# If no config file exists, set JARVIS_OPENAI_KEY to run in env-only mode
# JARVIS_OPENAI_KEY=sk-proj-...       (also reads OPENAI_API_KEY)
# JARVIS_BOT_NAME=Jarvis
# JARVIS_MEET_URL=https://meet.google.com/abc-defg-hij
# JARVIS_LANGUAGE=auto                 (auto, en, uk)
# JARVIS_TTS_VOICE=nova
# JARVIS_OPENAI_MODEL=gpt-5.4
# JARVIS_INTENT_MODEL=gpt-5
# JARVIS_RESPONSE_MODE=smart           (smart, name_only)
# JARVIS_TRANSCRIPTION_MODE=cloud      (cloud, local)
# JARVIS_WHISPER_MODEL=small
# JARVIS_PORT=8080
# JARVIS_BRIDGE_PORT=9090
# JARVIS_MAX_RESPONSE_TOKENS=150
# JARVIS_TEMPERATURE=0.7
# JARVIS_RECORD_VIDEO=false
# JARVIS_SYSTEM_PROMPT=...
# JARVIS_INTENT_PROMPT=...
# JARVIS_TOOLS=[{"name":"...","type":"curl",...}]
# RUST_LOG=jarvis=info
